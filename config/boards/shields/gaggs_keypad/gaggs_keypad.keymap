#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    /* 새로운 비헤이비어 정의 */
    behaviors {
        // 사실(Fact): 5초(5000ms) 이상 눌러야 작동하는 hold-tap 정의
        td_boot: tap_dance_bootloader {
            compatible = "zmk,behavior-hold-tap";
            label = "BOOTLOADER_LONG_PRESS";
            #binding-cells = <2>;
            tapping-term-ms = <5000>;     // 정확히 5초 설정
            flavor = "tap-preferred";     // 5초 전 떼면 무조건 Tap 키(Mute) 작동
            bindings = <&bootloader>, <&kp>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                /* --- 3x4 매트릭스 영역 --- */
                &kp KP_N7    &kp KP_N8    &kp KP_N9    &kp KP_MINUS
                &kp KP_N4    &kp KP_N5    &kp KP_N6    &kp KP_PLUS
                &kp KP_N1    &kp KP_N2    &kp KP_N3    &kp KP_ENTER

                /* --- 노브(Encoder) 스위치 영역 --- */
                // 사실(Fact): 첫 번째 인코더 클릭에 5초 홀드 기능 적용
                // &td_boot [홀드 시 동작] [탭 시 동작] 순서임
                &td_boot 0 C_MUTE    &kp C_PP    &kp C_NEXT    &none
            >;

            sensor-bindings = <
                &inc_dec_kp C_VOL_UP C_VOL_DN
                &inc_dec_kp PG_UP PG_DN
                &inc_dec_kp C_BRI_UP C_BRI_DN
            >;
        };
    };
};
